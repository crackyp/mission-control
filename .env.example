# Mission Control runtime configuration
# Copy to .env.local and adjust for your machine.

# Base directories
MC_HOME_DIR=/home/youruser
MC_CLAWD_DIR=/home/youruser/clawd
MC_SHARED_DIR=/home/youruser/shared
MC_OPENCLAW_DIR=/home/youruser/.openclaw

# Optional explicit paths
# MC_PROJECT_ROOT=/absolute/path/to/mission-control
# MC_SESSIONS_DIR=/home/youruser/.openclaw/agents/main/sessions
# MC_CRON_JOBS_FILE=/home/youruser/.openclaw/cron/jobs.json
# MC_AGENT_STATUS_FILE=/home/youruser/shared/agent-status.json
# MC_OPENCLAW_CONFIG_FILE=/home/youruser/.openclaw/openclaw.json
# MC_OPENCLAW_BIN=/home/youruser/.npm-global/bin/openclaw
# MC_TASKS_FILE_PATH=/absolute/path/to/mission-control/data/tasks.json
# MC_MEMORY_DIR=/home/youruser/clawd/memory

# Twitter integration
# MC_TWITTER_DIR=/home/youruser/shared/deliverables/kevteaches-content/twitter
# MC_TWITTER_ARCHIVE_DIR=/home/youruser/shared/deliverables/.archive/twitter
# MC_TWITTER_SCRIPT=/home/youruser/.openclaw/skills/twitter/twitter.py
# MC_TWITTER_POSTED_LOG=/home/youruser/clawd/data/twitter_posted.json

# WordPress integration
# MC_WP_WEB_DIR=/home/youruser/shared/deliverables/kevteaches-content/web/content
# MC_WP_ARCHIVE_DIR=/home/youruser/shared/deliverables/.archive/wordpress
# MC_WP_PROXY=http://127.0.0.1:8082/wp-proxy
# MC_WP_CREDS_FILE=/home/youruser/.openclaw/skills/wordpress/credentials.env

# Messaging defaults
MC_DEFAULT_DISCORD_CHANNEL_TO=channel:your-channel-id
MC_MAIN_DISCORD_SESSION_KEY=agent:main:discord:channel:your-channel-id

# Client-side default used in the Cron editor UI
NEXT_PUBLIC_DEFAULT_DISCORD_CHANNEL_TO=channel:your-channel-id
